{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/folders/layout,_N_T_/folders/page,_N_T_/folders"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/folders/__PAGE__",
    "/folders",
    "/_index",
    "/_head"
  ]
}